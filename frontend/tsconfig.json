{
    "compilerOptions": {
        "target": "ESNext",
        "useDefineForClassFields": true,
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "sourceMap": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "verbatimModuleSyntax": true
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.svelte"
    ],
    "exclude": [
        "node_modules"
    ]
}